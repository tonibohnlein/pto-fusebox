digraph Solution {
    rankdir=TB;
    node [fontname="Helvetica,Arial,sans-serif", fontsize=10];
    edge [fontname="Helvetica,Arial,sans-serif", fontsize=10];

    // --- Tensors ---
    T0 [label="Tensor 0\n512x512\n(256.0 KB)", shape=box, style=filled, fillcolor=lightblue];
    T1 [label="Tensor 1\n512x512\n(256.0 KB)", shape=box, style=filled, fillcolor=lightblue];
    T2 [label="Tensor 2\n512x512\n(256.0 KB)", shape=box, style=filled, fillcolor=lightblue];
    T3 [label="Tensor 3\n512x512\n(256.0 KB)", shape=box, style=filled, fillcolor=lightblue];
    T4 [label="Tensor 4\n512x512\n(256.0 KB)", shape=box, style=filled, fillcolor=lightblue];
    T5 [label="Tensor 5\n512x512\n(256.0 KB)", shape=box, style=filled, fillcolor=lightblue];
    T6 [label="Tensor 6\n512x512\n(256.0 KB)", shape=box, style=filled, fillcolor=lightblue];
    T7 [label="Tensor 7\n512x512\n(256.0 KB)", shape=box, style=filled, fillcolor=lightblue];
    T8 [label="Tensor 8\n512x512\n(256.0 KB)", shape=box, style=filled, fillcolor=lightblue];

    // --- Operations ---
    Op0 [label="Op 0\nMatMul\nCost: 2000\n---\nStep 0\nTile: 256x64x64\nLat: 125337.6\nRowMajor", shape=ellipse, style=filled, fillcolor="#ffb3ba"];
    Op1 [label="Op 1\nPointwise\nCost: 500\n---\nStep 1\nTile: 128x128x64\nLat: 134348.8\nColMajor", shape=ellipse, style=filled, fillcolor="#ffdfba"];
    Op2 [label="Op 2\nMatMul\nCost: 2000\n---\nStep 1\nTile: 128x128x64\nLat: 134348.8\nColMajor", shape=ellipse, style=filled, fillcolor="#ffdfba"];
    Op3 [label="Op 3\nMatMul\nCost: 2000\n---\nStep 1\nTile: 128x128x64\nLat: 134348.8\nColMajor", shape=ellipse, style=filled, fillcolor="#ffdfba"];
    Op4 [label="Op 4\nPointwise\nCost: 500\n---\nStep 1\nTile: 128x128x64\nLat: 134348.8\nColMajor", shape=ellipse, style=filled, fillcolor="#ffdfba"];

    // --- Data Edges ---
    T0 -> Op0;
    T1 -> Op0;
    Op0 -> T4;
    T4 -> Op1;
    Op1 -> T5;
    T5 -> Op2;
    T2 -> Op2;
    Op2 -> T6;
    T6 -> Op3;
    T3 -> Op3;
    Op3 -> T7;
    T7 -> Op4;
    T0 -> Op4;
    Op4 -> T8;
}